---
import { GlitchTitle } from "../pretext/GlitchTitle";
---

<section id="contact" class="cta">
  <div class="frame cta-frame">
    <span class="cross cross--tl" aria-hidden="true"></span>
    <span class="cross cross--tr" aria-hidden="true"></span>
    <span class="cross cross--bl" aria-hidden="true"></span>
    <span class="cross cross--br" aria-hidden="true"></span>

    <div class="cta-head" data-reveal>
      <p class="eyebrow">// 05 — Contact</p>
      <GlitchTitle client:visible as="h2" fz="var(--fs-4xl)" text="Prêt à passer à l'action ?" />
      <p class="cta-sub">Appelez-nous, on en discute.</p>
    </div>

    <div class="cta-tel" data-reveal style="--reveal-delay: 200ms">
      <a href="tel:+33674305067" aria-label="Appeler DMY au +33 6 74 30 50 67">
        <svg viewBox="0 0 24 24" width="0.62em" height="0.62em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        +33 6 74 30 50 67
      </a>
      <p class="cta-note">Réponse sous 24h — appel sans engagement.</p>
    </div>
  </div>
</section>

<style>
  .cta {
    background: var(--surface);
  }
  .cta-frame {
    position: relative;
    text-align: center;
  }
  .cta-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-3);
  }
  .cta-sub {
    max-width: 26rem;
    font-size: var(--fs-md);
    color: var(--text-3);
  }
  .cta-tel {
    margin-block: var(--sp-7) var(--sp-4);
  }
  .cta-tel a {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-size: var(--fs-tel);
    font-weight: 700;
    letter-spacing: var(--ls-title);
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
  }
  .cta-tel svg {
    color: var(--brand);
    flex-shrink: 0;
  }
  .cta-tel a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.15em;
    height: 3px;
    background: var(--brand);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--t-med) var(--ease-out);
  }
  .cta-tel a:hover::after,
  .cta-tel a:focus-visible::after {
    transform: scaleX(1);
  }
  .cta-note {
    margin-top: var(--sp-4);
    font-size: var(--fs-sm);
    color: var(--text-3);
  }

  .cross {
    position: absolute;
    width: 9px;
    height: 9px;
    background:
      linear-gradient(var(--brand), var(--brand)) center / 1px 100% no-repeat,
      linear-gradient(var(--brand), var(--brand)) center / 100% 1px no-repeat;
    pointer-events: none;
  }
  .cross--tl { top: -5px; left: -5px; }
  .cross--tr { top: -5px; right: -4px; }
  .cross--bl { bottom: -4px; left: -5px; }
  .cross--br { bottom: -4px; right: -4px; }

  @media (prefers-reduced-motion: reduce) {
    .cta-tel a::after { transition: none; }
  }
</style>
