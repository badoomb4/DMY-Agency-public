---
interface Card {
  title: string;
  text: string;
  stack?: string;
}

interface Props {
  id: string;
  title: string;
  intro: string;
  cards: Card[];
  /** Fond blanc (sinon fond gris --bg). */
  alt?: boolean;
}

const { id, title, intro, cards, alt = false } = Astro.props;
---

<section id={id} class:list={["svc", { "svc--alt": alt }]}>
  <div class="container container--text">
    <h2>{title}</h2>
    <p class="intro">{intro}</p>
    <div class="cards-grid">
      {cards.map((card) => (
        <article class="card">
          <h3>{card.title}</h3>
          <p>{card.text}</p>
          {card.stack && <p class="stack">{card.stack}</p>}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .svc {
    background: var(--bg);
    padding-block: var(--section-y);
  }
  .svc--alt {
    background: var(--surface);
  }
  h2 {
    font-size: var(--fs-3xl);
    font-weight: 700;
    letter-spacing: var(--ls-title);
    line-height: var(--lh-snug);
    color: var(--text);
  }
  .intro {
    margin-block: var(--sp-4) var(--sp-6);
    max-width: 44rem;
    font-size: var(--fs-base);
    color: var(--text-3);
    line-height: var(--lh-loose);
  }
  .card h3 {
    font-size: var(--fs-lg);
    font-weight: 700;
    letter-spacing: var(--ls-title);
    color: var(--text);
    margin-bottom: var(--sp-2);
  }
  .card p {
    font-size: var(--fs-sm);
    color: var(--text-3);
    line-height: var(--lh-base);
  }
  .card .stack {
    margin-top: var(--sp-3);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-3);
  }
  /* Cartes blanches sur fond gris, grises sur fond blanc. */
  .svc .card {
    background: var(--surface);
  }
  .svc--alt .card {
    background: var(--bg);
  }
</style>
