---
import "../styles/tokens.css";
import "../styles/fonts.css";
import "../styles/base.css";
import "../styles/layout.css";
import "../styles/buttons.css";
import "../styles/services.css";
import "../styles/process.css";
import "../styles/faq.css";
import "../styles/reveal.css";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
}

const { title, description, canonicalPath = "/", ogImage = "/og-image.png" } = Astro.props;
const siteUrl = "https://dmy-agency.com";
const canonical = `${siteUrl}${canonicalPath}`;
const ogImageUrl = `${siteUrl}${ogImage}`;
---

<html lang="fr" class="no-js">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      document.documentElement.classList.remove("no-js");
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="DMY" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="DMY — Développement sur mesure & Conseil en Intelligence Artificielle" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <slot name="head" />

    <link rel="preload" href="/fonts/geist-sans-latin-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/geist-sans-latin-700.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <a class="skip-link" href="#main">Aller au contenu</a>
    <slot />
    <script src="../scripts/reveal.js"></script>
  </body>
</html>
