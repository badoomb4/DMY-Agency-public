---
import Layout from "../layouts/Layout.astro";
import CategoryDivider from "../components/CategoryDivider.astro";
import Navbar from "../components/astro/Navbar.astro";
import Footer from "../components/astro/Footer.astro";
import Hero from "../components/astro/Hero.astro";
import Pricing from "../components/astro/Pricing.astro";
import Faq from "../components/astro/Faq.astro";
import CtaFinal from "../components/astro/CtaFinal.astro";
import { Services } from "../components/sections/Services";
import { Process } from "../components/sections/Process";
import { faqs } from "../data/faq";
---

<Layout
  title="DMY — Développement sur mesure & Conseil en Intelligence Artificielle"
  description="DMY conçoit vos applications web, mobiles, bots et automatisations sur mesure. Conseil en IA, intégration d'agents intelligents et formation équipes. Devis gratuit."
  canonicalPath="/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "DMY",
      "url": "https://dmy-agency.com",
      "description": "Services informatiques sur mesure et conseil en intelligence artificielle.",
      "telephone": "+33674305067",
      "areaServed": "Europe",
      "knowsLanguage": ["fr", "en"],
      "serviceType": ["Développement web", "Développement mobile", "Conseil IA", "Automatisation", "Chatbots"]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map((f) => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": { "@type": "Answer", "text": f.answer },
      })),
    })} />
  </Fragment>

  <Navbar />
  <main id="main">
    <Hero />
    <CategoryDivider />
    <Services client:visible />
    <CategoryDivider />
    <Process client:visible />
    <CategoryDivider />
    <Pricing />
    <CategoryDivider />
    <Faq />
    <CategoryDivider />
    <CtaFinal />
  </main>
  <Footer />
</Layout>
