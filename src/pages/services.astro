---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/astro/Navbar.astro";
import Footer from "../components/astro/Footer.astro";
import CtaFinal from "../components/astro/CtaFinal.astro";
import ServiceCardGrid from "../components/astro/ServiceCardGrid.astro";

const dev = [
  {
    title: "Applications Web",
    text: "SaaS, dashboards analytics, portails clients, back-offices. Architecture React/Next.js, interfaces réactives, déploiement continu. Vos utilisateurs accèdent à un produit fiable depuis n'importe quel navigateur.",
    stack: "React · Next.js · Astro · Supabase",
  },
  {
    title: "Applications Mobile",
    text: "Une seule codebase, deux plateformes. Applications iOS et Android cross-platform avec expérience native : notifications push, mode hors-ligne, performances fluides. De l'idée au store en quelques semaines.",
    stack: "React Native · Expo · Flutter · Firebase",
  },
  {
    title: "Bots Telegram & WhatsApp",
    text: "Transformez vos canaux de messagerie en véritables outils métier. Gestion de commandes, notifications, pilotage CRM et réponses clients 24h/24 — avec ou sans IA embarquée.",
    stack: "Telegram · WhatsApp · LLM · Webhooks",
  },
  {
    title: "Sites Vitrines & E-commerce",
    text: "Sites rapides, accessibles et optimisés pour le référencement. Vitrine corporate, landing pages de conversion ou boutique en ligne complète — stack adaptée à votre budget.",
    stack: "Astro · Shopify · Stripe · SEO · CMS",
  },
];

const automatisation = [
  {
    title: "Workflows automatisés",
    text: "Connexion de vos outils existants (CRM, ERP, Google Workspace, Notion, Slack) via des pipelines sur mesure. Déclenchement par événements, planification cron, ou appels API.",
  },
  {
    title: "Scraping & Data pipelines",
    text: "Collecte, nettoyage et structuration de données depuis n'importe quelle source. Alimentation automatique de vos bases, tableaux de bord et outils de reporting.",
  },
  {
    title: "Alertes & Monitoring",
    text: "Surveillance de vos processus critiques avec notifications en temps réel. Détection d'anomalies, rapports automatiques et escalade intelligente.",
  },
];

const conseil = [
  {
    title: "Audit & Stratégie IA",
    text: "Cartographie de vos processus, données et points de friction. Identification des cas d'usage IA à fort ROI et construction d'une feuille de route réaliste — pas de buzzwords, que du concret avec des résultats mesurables à 3 mois.",
  },
  {
    title: "Agents IA connectés",
    text: "Déploiement d'assistants IA connectés à vos plateformes. Vos équipes gagnent du temps, vos clients obtiennent des réponses instantanées — sécurisé et intégré à votre écosystème existant.",
  },
  {
    title: "Formation Équipes",
    text: "Vos collaborateurs apprennent à tirer le meilleur de l'IA au quotidien : prompts efficaces, intégration d'outils IA dans leurs workflows, bonnes pratiques de sécurité. Formation par la pratique, sur vos cas réels.",
  },
];
---

<Layout
  title="Services — Développement sur mesure, Conseil IA & Automatisation | DMY"
  description="Applications web, mobiles, bots Telegram & WhatsApp, automatisations et conseil en intelligence artificielle. Découvrez l'ensemble des services DMY pour accélérer votre entreprise."
  canonicalPath="/services"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "provider": { "@type": "Organization", "name": "DMY", "url": "https://dmy-agency.com" },
      "serviceType": ["Développement web", "Développement mobile", "Chatbots", "Automatisation", "Conseil IA"],
      "areaServed": "Europe",
      "availableLanguage": ["fr", "en"]
    })} />
  </Fragment>

  <Navbar />
  <main id="main">
    <section class="page-hero">
      <div class="container container--text">
        <p class="eyebrow">// Nos services</p>
        <h1>Tout ce qu'il faut pour passer de l'idée au produit.</h1>
        <p class="lead">
          On conçoit, développe et déploie des solutions digitales sur mesure.
          Chaque projet est pensé pour votre métier, vos contraintes et vos ambitions.
        </p>
      </div>
    </section>

    <ServiceCardGrid
      id="developpement"
      title="Développement sur mesure"
      intro="On ne vend pas des templates. On construit des applications taillées pour votre métier, avec une architecture pensée pour durer et évoluer."
      cards={dev}
      alt
    />

    <ServiceCardGrid
      id="automatisation"
      title="Automatisation"
      intro="On identifie les tâches répétitives qui freinent vos équipes et on les automatise. Synchronisation de données, génération de documents, alertes intelligentes, pipelines ETL. Moins de travail manuel, plus de fiabilité."
      cards={automatisation}
    />

    <ServiceCardGrid
      id="conseil-ia"
      title="Conseil en Intelligence Artificielle"
      intro="L'IA n'est pas une fin en soi — c'est un levier. On vous aide à l'intégrer là où elle crée de la valeur, pas là où elle fait joli."
      cards={conseil}
      alt
    />

    <CtaFinal />
  </main>
  <Footer />
</Layout>

<style>
  .page-hero {
    background: var(--bg);
    padding-block: var(--hero-y) var(--section-y);
    text-align: center;
  }
  .eyebrow {
    margin-bottom: var(--sp-2);
  }
  h1 {
    font-size: var(--fs-4xl);
    font-weight: 700;
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-display);
    color: var(--text);
  }
  .lead {
    margin-top: var(--sp-4);
    font-size: var(--fs-md);
    color: var(--text-3);
  }
</style>
